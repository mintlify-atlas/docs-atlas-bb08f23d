  "keyFeatures": [
    "AI-powered code error detection and fixing",
    "Interactive terminal UI built with React and Ink",
    "Multiple AI model support (OpenRouter, Google GenAI, OpenAI)",
    "Comprehensive file operations (read, write, create, delete)",
    "Natural language command processing",
    "Authentication and configuration management",
    "Real-time streaming responses",
    "Project file tree visualization"
  ],
  "publicApiSurface": [
    "getConfig() - Retrieve CLI configuration",
    "setConfig(key, value) - Update configuration",
    "deleteConfig(key) - Remove configuration",
    "readFile(path) - Read file contents",
    "writeFile(path, content) - Write to file",
    "createFile(path, content) - Create new file",
    "deleteFile(path) - Delete file",
    "getFileTree(dir) - Get project structure",
    "useChat() - Chat hook for AI interactions",
    "useToolExecutor() - Hook for tool execution",
    "isAuthenticated() - Check auth status",
    "isModelSelected() - Check model selection",
    "/model - Select AI model command",
    "/help - Display help command",
    "/path - Set working path command",
    "/apikey - Configure API key command",
    "/logout - Logout command",
    "/report - Report issue command",
    "/exit - Exit CLI command"
  ]
